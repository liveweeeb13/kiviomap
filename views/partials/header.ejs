<body data-is-logged="<%= user ? 'true' : 'false' %>">
<nav class="navbar">
  <a class="nav-brand" href="/">Kiviomap</a>
  <div class="nav-links">
    <a href="/leaderboard">Classement</a>
    <% if (user) { %>
      <% if (user.role === 'admin') { %><a href="/admin" class="btn-primary">Admin</a><% } %>
      <a href="/account" class="user-badge" style="text-decoration:none;cursor:pointer;">
        <%= user.username %>
        <small><%= user.points %> pts</small>
      </a>
    <% } else { %>
      <a href="/auth/login">Connexion</a>
      <a href="/auth/register" class="btn-primary">S'inscrire</a>
    <% } %>
  </div>
</nav>
