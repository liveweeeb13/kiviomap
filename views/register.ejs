<%- include('partials/header') %>
<div class="auth-page">
  <div class="auth-box">
    <h1>Créer un compte</h1>
    <p class="auth-subtitle">Rejoignez la communauté Kiviomap</p>
    <% if (error) { %><div class="alert-error"><%= error %></div><% } %>
    <form method="POST" action="/auth/register">
      <label>Pseudo<input type="text" name="username" required minlength="3" autofocus placeholder="votre_pseudo"></label>
      <label>Email<input type="email" name="email" required placeholder="vous@exemple.com"></label>
      <label>Mot de passe<input type="password" name="password" required minlength="6" placeholder="6 caractères minimum"></label>
      <label>Confirmer le mot de passe<input type="password" name="confirm_password" required placeholder="••••••••"></label>
      <button type="submit" class="btn-primary btn-full">Créer mon compte</button>
    </form>
    <p class="auth-link">Déjà un compte ? <a href="/auth/login">Se connecter</a></p>
  </div>
</div>
<%- include('partials/footer') %>
