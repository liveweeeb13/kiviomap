<%- include('partials/header') %>
<div class="auth-page">
  <div class="auth-box">
    <h1>Nouveau mot de passe</h1>
    <p class="auth-subtitle">Choisis un nouveau mot de passe</p>
    <% if (error) { %><div class="alert-error"><%= error %></div><% } %>
    <form method="POST" action="/auth/reset/<%= token %>">
      <label>Nouveau mot de passe<input type="password" name="password" required autofocus placeholder="••••••••" minlength="6"></label>
      <label>Confirmer<input type="password" name="confirm_password" required placeholder="••••••••"></label>
      <button type="submit" class="btn-primary btn-full">Réinitialiser</button>
    </form>
    <p class="auth-link"><a href="/auth/login">← Retour à la connexion</a></p>
  </div>
</div>
<%- include('partials/footer') %>
