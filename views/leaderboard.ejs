<%- include('partials/header') %>
<div class="leaderboard-page">
  <h1>Classement</h1>

  <div class="lb-grid">
    <div class="detail-card">
      <h3>Top contributeurs</h3>
      <ol>
        <% topPoints.forEach((u, i) => { %>
        <li>
          <span class="lb-rank"><%= i+1 %></span>
          <a href="/u/<%= u.id %>" class="user-badge" style="text-decoration:none"><%= u.username %></a>
          <span class="lb-pts"><%= u.points %> pts</span>
        </li>
        <% }) %>
      </ol>
    </div>

    <div class="detail-card">
      <h3>Plus de réseaux ajoutés</h3>
      <ol>
        <% topNetworks.forEach((u, i) => { %>
        <li><span class="lb-rank"><%= i+1 %></span> <a href="/u/<%= u.id %>" style="color:var(--text);text-decoration:none"><%= u.username %></a> <span class="lb-pts"><%= u.count %> réseaux</span></li>
        <% }) %>
      </ol>
    </div>

  </div>
</div>
<%- include('partials/footer') %>
